# HPC user configuration template
# Copy to config.env and fill in your details — config.env is gitignored.

# Your M3 username
HPC_USER=your_username

# Your M3 scratch/project directory (parent of the repo)
HPC_SCRATCH_DIR=/home/your_username/your_project_code

# Full path to the project on M3
HPC_PROJECT_DIR=/home/your_username/your_project_code/robust_prioritizr_paper

# Email for SLURM notifications
SLURM_EMAIL=your_email@monash.edu
